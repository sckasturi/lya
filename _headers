# Cloudflare Pages headers.

# Security headers (Lighthouse Best Practices: HSTS, clickjacking).
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# Hashed build assets are immutable — cache them for a year.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Stable-named files (rename the file if you ever replace it).
/assets/hero/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=604800

/favicon.ico
  Cache-Control: public, max-age=604800

/apple-touch-icon.png
  Cache-Control: public, max-age=604800

/og-image.jpg
  Cache-Control: public, max-age=86400

# Never cache the HTML shell so deploys go live immediately.
/index.html
  Cache-Control: no-cache
